{
  "manifest_version": 3,
  "name": "Calendar AI",
  "version": "3.0.0",

  "permissions": ["storage"],
  "host_permissions": ["https://calendar.google.com/*"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://calendar.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {}
}